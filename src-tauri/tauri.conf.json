{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Genesis Magma",
  "version": "0.1.0",
  "identifier": "kr.ac.tu.genesismagma",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node server.js",
    "beforeBuildCommand": "node scripts/copy-web.mjs"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Genesis Magma",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
